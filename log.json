{
    "version": 1
    , "disable_existing_loggers": false
    , "formatters": {
        "simple": {
            "class": "logging.Formatter"
            , "format": "{name:^24.24}\u2503 {message}"
            , "style": "{"
        }
        , "detailed": {
            "class": "logging.Formatter"
            , "datefmt": "%Y-%m-%d %H:%M:%S"
            , "format": "{asctime:s}:{msecs:03.0f}‖{levelname:^5.8s}=>{name:^24s}-> {message:s}"
            , "style": "{"
        }
    }
    , "filters": {
        "warnings_and_below": {
            "()" : "__main__.filter_maker"
            , "level": "WARNING"
        }
    }
    , "handlers": {
        "stdout": {
            "class": "logging.StreamHandler"
            , "level": "INFO"
            , "formatter": "simple"
            , "stream": "ext://sys.stdout"
            , "filters": [ "warnings_and_below" ]
        }
        , "stderr": {
            "class": "logging.StreamHandler"
            , "level": "ERROR"
            , "formatter": "simple"
            , "stream": "ext://sys.stderr"
        }
        , "file": {
            "class": "logging.FileHandler"
            , "formatter": "detailed"
            , "filename": "log.txt"
            , "mode": "a"
        }
    }
    , "root": {
        "level": "DEBUG"
        , "handlers": [
            "stderr"
            , "stdout"
            , "file"
        ]
    }
}